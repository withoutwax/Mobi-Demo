# ============================================================
# Spring Boot + Kotlin + Gradle .gitignore
# ============================================================

# ---- Gradle ------------------------------------------------
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# ---- IntelliJ IDEA -----------------------------------------
.idea/
*.iws
*.iml
*.ipr
out/
!**/src/main/**/out/
!**/src/test/**/out/

# ---- VS Code -----------------------------------------------
.vscode/

# ---- macOS -------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# ---- Spring Boot / JVM ------------------------------------
*.jar
*.war
*.ear
*.class
hs_err_pid*
replay_pid*

# ---- Logs --------------------------------------------------
logs/
*.log
*.log.*

# ---- 환경 변수 / 시크릿 (절대 커밋 금지) ----------------------
.env
.env.local
.env.*.local
!.env.example

# ---- 테스트 리포트 -----------------------------------------
test-results/
jacoco/
